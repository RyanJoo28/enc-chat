DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=enc_chat_db
JWT_SECRET_KEY=change_this_to_a_secure_random_hex_string
DB_ENCRYPTION_KEY=change_this_to_a_secure_random_hex_string
APP_LOG_LEVEL=INFO
APP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1],testserver,*.localhost
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost:3000,http://127.0.0.1:3000,https://127.0.0.1:3000
APP_CORS_ALLOWED_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?$
E2EE_PRIVATE_ENABLED=true
E2EE_GROUP_ENABLED=true
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_SESSION_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
WS_TICKET_TTL_SECONDS=60
WS_MAX_MESSAGE_BYTES=65536
WS_MAX_MESSAGES_PER_MINUTE=120
E2EE_ATTACHMENT_MAX_BYTES=20971520
E2EE_ATTACHMENT_UPLOAD_TTL_MINUTES=60
