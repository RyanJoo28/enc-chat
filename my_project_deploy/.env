COMPOSE_PROJECT_NAME=enc-chat-release
APP_PORT=23456

# Optional GHCR overrides for forks or private re-publishes.
# Leave these commented to use the default image values from docker-compose.yml.
# BACKEND_IMAGE=ghcr.io/<github-namespace>/enc-chat-backend:<tag>
# FRONTEND_IMAGE=ghcr.io/<github-namespace>/enc-chat-frontend:<tag>

MYSQL_ROOT_PASSWORD=enc_chat_root_password
MYSQL_DATABASE=enc_chat_db
MYSQL_USER=enc_chat
MYSQL_PASSWORD=enc_chat_password

SERVER_NAME=localhost
TLS_COMMON_NAME=localhost
TLS_DOMAINS=localhost,127.0.0.1
TLS_CERT_DAYS=825

JWT_SECRET_KEY=
DB_ENCRYPTION_KEY=
E2EE_PRIVATE_ENABLED=true
E2EE_GROUP_ENABLED=true
